# ==================================================================
# Exemplo de variáveis de ambiente. Copie para .env e preencha.
# NUNCA versione o .env real (está no .gitignore).
# ==================================================================

# Ambiente de execução da pipeline: local | aws
APP_ENV=local

# ---- AWS ----------------------------------------------------------
AWS_REGION=us-east-1
# Preferível usar `aws configure` / perfil IAM em vez de chaves aqui.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_PROFILE=default

# ---- Data lake ----------------------------------------------------
S3_BUCKET=tc2-alfabetizacao-datalake

# ---- Streaming (Kinesis) ------------------------------------------
KINESIS_STREAM=tc2-alfabetizacao-eventos

# ---- Observabilidade ----------------------------------------------
SNS_TOPIC=tc2-alfabetizacao-alertas

# ---- Athena -------------------------------------------------------
ATHENA_OUTPUT=s3://tc2-alfabetizacao-datalake/athena-results/

# ---- LocalStack (opcional, para emular S3/Kinesis local) ----------
# AWS_ENDPOINT_URL=http://localhost:4566
